# Application Settings
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
# Application Settings
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=0

# Server Settings
HOST=0.0.0.0
PORT=5000

# MongoDB Settings (Local or Atlas)
# Local MongoDB with authentication:
MONGODB_URI=mongodb://flaskuser:flaskpass123@localhost:27017/flask_db?authSource=admin

# MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# MongoDB Credentials (used by Flask when building URI)
MONGODB_USERNAME=flaskuser
MONGODB_PASSWORD=flaskpass123

# MongoDB Database Configuration
MONGO_INITDB_DATABASE=flask_db
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123secure
MONGO_COLLECTION_NAME=data

